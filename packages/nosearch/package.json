{
  "name": "@raquezha/nosearch",
  "version": "0.0.4",
  "description": "Integrated Brave Search and Firecrawl subagent wrapper extension for the Pi Coding Agent",
  "main": "dist/nosearch.js",
  "type": "module",
  "bin": {
    "nosearch-install": "bin/nosearch-install.cjs"
  },
  "files": [
    "dist",
    "bin",
    "brave-search",
    "firecrawl",
    "_worker.sh",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": ">=0.74.0",
    "@earendil-works/pi-ai": ">=0.74.0"
  },
  "dependencies": {
    "typebox": "^1.2.1"
  },
  "devDependencies": {
    "typescript": "^5.0.0"
  },
  "keywords": [
    "pi-agent",
    "search",
    "brave",
    "firecrawl",
    "subagent",
    "pi-package"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "types": "dist/nosearch.d.ts",
  "pi": {
    "extensions": [
      "extensions"
    ],
    "skills": [
      "brave-search",
      "firecrawl"
    ]
  }
}
