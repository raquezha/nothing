{
  "name": "nothing-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Unified dotfiles configuration and extensions monorepo",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "node scripts/verify-repo.mjs",
    "changeset:status": "changeset status --since=origin/main",
    "verify:notrace": "node scripts/verify-notrace.mjs",
    "compare:notrace": "node scripts/notrace-compare.mjs",
    "review:notrace": "node scripts/notrace-review.mjs",
    "version": "changeset version",
    "release": "changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.1"
  },
  "dependencies": {
    "headroom-ai": "^0.22.4",
    "openai": "^6.42.0"
  }
}
